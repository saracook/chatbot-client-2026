[connection]
id={{ interface }}
uuid={{ hostvars[hostname]['interfaces'][interface]['uuid'] }}
type=bridge
interface-name={{ interface }}

[ethernet]
mtu={{ network_mtu }}

[bridge]
stp=on

[ipv4]
method=manual
address={{ hostvars[hostname]['interfaces'][interface]['address'] | join(";") }};
gateway={{ hostvars[hostname]['interfaces'][interface]['gateway'] }}
dns={{ hostvars[hostname]['interfaces'][interface]['dns'] | join(";") }};
dns-search={{ hostvars[hostname]['interfaces'][interface]['dns_search_domain'] | join(";") }};

[ipv6]
method=disabled

[proxy]
