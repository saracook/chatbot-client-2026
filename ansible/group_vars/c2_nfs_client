nfs_server: h700.cluster.carina
nfs_mounts:
  - src: "{{ nfs_server }}:/admin"
    path: /admin
    fstype: nfs4
    opts: defaults,_netdev,sec=sys,sync
    dump: 0
    passno: 0
  - src: "{{ nfs_server }}:/home"
    path: /home/users
    fstype: nfs4
    opts: defaults,_netdev,sec=sys,sync
    dump: 0
    passno: 0
  - src: "{{ nfs_server }}:/projects"
    path: /projects
    fstype: nfs4
    opts: defaults,_netdev,sec=sys,sync
    dump: 0
    passno: 0
  - src: "{{ nfs_server }}:/software"
    path: /software
    fstype: nfs4
    opts: defaults,_netdev,sec=sys,sync
    dump: 0
    passno: 0
