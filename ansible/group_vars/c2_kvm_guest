vcpus: 2
memory_gb: 8
swapfile_gb: 2
# eth0 assumes net.ifnames=0 boot option
# without this default is enp1s0
nic_1: eth0
boot_disk_dev: vda
boot_disk_gb: 32
boot_disk_bytes: "{{ boot_disk_gb * 1024 * 1024 * 1024 }}"
data_disk_dev: vdb
data_disk_gb: 64
data_disk_bytes: "{{ data_disk_gb * 1024 * 1024 * 1024 }}"
