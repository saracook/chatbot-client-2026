---
title: 'Carina Desktop'
cluster: '{{ slurm_cluster_name }}'
submit: 'submit/{{ slurm_cluster_name }}.yml.erb'
description: |
  This app will launch an [Xfce] interactive desktop on a compute node.

  [Xfce]: https://www.xfce.org/

form:
  - desktop
  - bc_account
  - bc_queue
  - fs_size
  - fs_gpu
  - bc_num_hours
  - bc_email_on_started

attributes:
  desktop: 'xfce'
  bc_account: 'users'
  bc_queue: 'dev'

  fs_size:
    label: 'Size'
    widget: 'select'
    options:
      - [ 'Tiny', 'tiny' ]
      - [ 'Small', 'small' ]
      - [ 'Medium', 'medium' ]
      - [ 'Large', 'large' ]
    value: 'small'
    help: |
      <small>

        - **Tiny**: 2 core, 8 GB
        - **Small**: 4 cores, 16 GB
        - **Medium**: 8 cores, 32 GB
        - **Large**: 16 cores, 64 GB

      </small>

  fs_gpu:
    label: 'Allocate a GPU'
    widget: 'check_box'

  bc_num_hours:
    value: 1
    max: 24
