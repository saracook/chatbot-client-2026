# https://osc.github.io/ood-documentation/latest/customizations.html#set-ssh-allowlist
{% if ood_tier != 'prod' %}
OOD_SSHHOST_ALLOWLIST="{{ ( groups['c2_compute_node'] | map('regex_replace', '$', '.' ~ network_access_domain) | join(':') ) ~ ':' ~ inventory_hostname ~ '.' ~ network_access_domain }}"
{% else %}
OOD_SSHHOST_ALLOWLIST="{{ groups['c2_compute_node'] | map('regex_replace', '$', '.' ~ network_access_domain) | join(':') }}"
{% endif %}

# https://osc.github.io/ood-documentation/latest/customizations.html#enable-and-configure-shell-ping-pong
OOD_SHELL_PING_PONG=true
# 15 minutes
OOD_SHELL_INACTIVE_TIMEOUT_MS=900000
# 30 minutes
OOD_SHELL_MAX_DURATION_MS=1800000
