---
batch_connect:
  template: 'basic'
  conn_params:
    - password

script:
  native: [
    <% case fs_size when "tiny" %>
    '--cpus-per-task', 2,
    '--mem', '8G',
    <% when "small" %>
    '--cpus-per-task', 4,
    '--mem', '16G',
    <% when "medium" %>
    '--cpus-per-task', 8,
    '--mem', '32G',
    <% else %>
    '--cpus-per-task', 16,
    '--mem', '64G',
    <% end %>
    <% if fs_gpu.to_i == 1 %>
    '--gpus', 1,
    <% end %>
    '--qos', 'normal'
  ]
