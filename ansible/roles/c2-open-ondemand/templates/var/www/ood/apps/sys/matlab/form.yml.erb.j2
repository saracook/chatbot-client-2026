---
title: 'MATLAB'
cluster: 'c2'

form:
  - bc_account
  - bc_queue
  - exec_mode
  - matlab_version
  - fs_size
  - fs_gpu
  - bc_num_hours
  - bc_email_on_started

attributes:

  bc_account: 'users'
  bc_queue: 'dev'

  exec_mode: 'module'
# todo: add container option
#  exec_mode:
#    label: 'Execution Mode'
#    widget: 'select'
#    options:
#      - [ 'Module', 'module' ]
#      - [ 'Container', 'container' ]
#    value: 'module'
#    help: Execute MATLAB using either environment module or container.

  matlab_version:
    label: 'MATLAB Version'
    widget: 'select'
    options:
      - 'R2025b'
    value: 'R2025b'

  fs_size:
    label: 'Size'
    widget: 'select'
    options:
      - [ 'Tiny', 'tiny' ]
      - [ 'Small', 'small' ]
      - [ 'Medium', 'medium' ]
      - [ 'Large', 'large' ]
    value: 'small'
    help: |
      <small>

        - **Tiny**: 2 core, 8 GB
        - **Small**: 4 cores, 16 GB
        - **Medium**: 8 cores, 32 GB
        - **Large**: 16 cores, 64 GB

      </small>

  fs_gpu:
    label: 'Allocate a GPU'
    widget: 'check_box'

  bc_num_hours:
    value: 1
    max: 2
