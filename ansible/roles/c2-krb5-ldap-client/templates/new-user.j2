#!/bin/bash

# create home directory and on-board to slurm

set -e

HOMEBASE="/home/users"
SACCTMGR="/usr/bin/sacctmgr"
DEFACCT="users"
DEFPART="dev"

# skip for root/*.root users
[ "$( echo $PAM_USER | cut -d '.' -f 2 )" = 'root' ] && exit 0
# skip for rocky user
[ "$PAM_USER" = 'rocky' ] && exit 0

# create user home directory
[ -d $HOMEBASE ] || mkdir -p $HOMEBASE
if [ ! -d $HOMEBASE/$PAM_USER ]
then
  cp -r /etc/skel $HOMEBASE/$PAM_USER
  chown -R $PAM_USER: $HOMEBASE/$PAM_USER
  chmod 00700 $HOMEBASE/$PAM_USER
fi

# skip slurm user accounting if slurm not installed
[ -x $SACCTMGR ] || exit 0

# ensure that slurm default users account exists
if [ -z "$( $SACCTMGR -nP list account name=$DEFACCT format=account )" ]
then
  $SACCTMGR -i create account name=$DEFACCT
fi

# ensure that slurm user is associated with default users account
if [ -z "$( $SACCTMGR -nP list user name=$PAM_USER defaultaccount=$DEFACCT format=user )" ]
then
  $SACCTMGR -i add user name=$PAM_USER account=$DEFACCT defaultaccount=$DEFACCT partition=$DEFPART
fi
