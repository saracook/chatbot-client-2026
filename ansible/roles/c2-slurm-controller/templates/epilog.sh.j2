#!/bin/bash
#
# Slurm epilog script
#
# purge local scratch space (happens at the end of each job, no matter what
# else is running on the node)
LOCAL_SCRATCH_ROOT="/local/scratch"
LOCAL_SCRATCH_USER=$LOCAL_SCRATCH_ROOT/$SLURM_JOB_USER
LOCAL_SCRATCH_JOB=$LOCAL_SCRATCH_USER/$SLURM_JOB_ID
[[ -d "$LOCAL_SCRATCH_JOB" ]] && rm -Rf "$LOCAL_SCRATCH_JOB"

exit 0
