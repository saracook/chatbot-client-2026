#!/bin/bash

# Configuration
DEV_QOS="dev"
NORMAL_QOS="normal"
LONG_QOS="long"

# Function to check and apply QOS settings
setup_qos() {
    local qos_name=$1
    local max_jobs=$2
    local max_tres=$3
    local flags="DenyOnLimit"

    echo "Checking QOS: $qos_name..."

    # 1. Check if QOS exists
    if ! sacctmgr --noheader show qos format=Name | grep -qw "$qos_name"; then
        echo "Creating $qos_name QOS..."
        sacctmgr -i add qos "$qos_name" || { echo "Failed to create $qos_name"; return 1; }
    fi

    # 2. Get current settings from Slurm to compare
    # We fetch Name, MaxJobsPU, MaxTRESPU, and Flags
    current_vals=$(sacctmgr --noheader --parsable2 show qos "$qos_name" format=MaxJobsPU,MaxTRESPU,Flags)
    
    # Slurm output massaging
    IFS='|' read -r curr_jobs curr_tres curr_flags <<< "$current_vals"

    # 3. Check if update is needed
    if [[ "$curr_jobs" == "$max_jobs" ]] && [[ "$curr_tres" == "$max_tres" ]] && [[ "$curr_flags" == *"$flags"* ]]; then
        echo "Settings for $qos_name are already up to date. Skipping."
    else
        echo "Updating $qos_name parameters..."
        sacctmgr -i modify qos "$qos_name" set MaxJobsPU="$max_jobs" MaxTRESPU="$max_tres" Flags="$flags"
        
        if [ $? -eq 0 ]; then
            echo "Successfully updated $qos_name"
        else
            echo "Error updating $qos_name"
            return 1
        fi
    fi
    echo "-----------------------------------"
}

# Execute for each QOS
# Usage: setup_qos "NAME" "MaxJobsPU" "MaxTRESPU"
setup_qos "$DEV_QOS" "1" "cpu=16,gres/gpu=1,mem=64G"
setup_qos "$NORMAL_QOS" "10" "cpu=256,gres/gpu=8,mem=1T"
setup_qos "$LONG_QOS" "1" "cpu=256,gres/gpu=1,mem=1T"
