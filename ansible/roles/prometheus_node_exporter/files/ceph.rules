- name: Ceph Alerts
  rules:
    - alert: HostUnusualDiskReadLatency
      expr: rate(diskio_read_time{job!="ceph"}[1m]) / rate(diskio_reads{job!="ceph"}[1m]) > 0.1 and rate(diskio_reads{job!="ceph"}[1m]) > 0
      for: 2m
      labels:
        severity: warning
      annotations:
        summary: "Host unusual disk read latency (instance {{ $labels.instance }})"
        description: "Disk latency is growing (read operations > 100ms)\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P3

    - alert: HostUnusualDiskWriteLatency
      expr: rate(diskio_write_time{job!="ceph"}[1m]) / rate(diskio_writes{job!="ceph"}[1m]) > 0.1 and rate(diskio_writes{job!="ceph"}[1m]) > 0
      for: 2m
      labels:
        severity: warning
      annotations:
        summary: "Host unusual disk write latency (instance {{ $labels.instance }})"
        description: "Disk latency is growing (write operations > 100ms)\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P3

    - alert: CPUUsageUserHigh
      expr: 100 - (avg by(instance) (rate(cpu_usage_user[2m])) * 100) > 80
      for: 2m
      labels:
        severity: critical
      annotations:
        summary: "High CPU user usage (instance {{ $labels.instance }})"
        description: "CPU user usage is greater than 80%\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P2

    - alert: CPUUsageSystemHigh
      expr: 100 - (avg by(instance) (rate(cpu_usage_system[2m])) * 100) > 80
      for: 2m
      labels:
        severity: critical
      annotations:
        summary: "High CPU system usage (instance {{ $labels.instance }})"
        description: "CPU system usage is greater than 80%\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P2

    - alert: CPUUsageIdleLow
      expr: 100 - (avg by(instance) (rate(cpu_usage_idle[2m])) * 100) < 10
      for: 2m
      labels:
        severity: critical
      annotations:
        summary: "Low CPU idle (instance {{ $labels.instance }})"
        description: "CPU idle is less than 10%\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P2

    - alert: CPUUsageIOWaitHigh
      expr: 100 - (avg by(instance) (rate(cpu_usage_iowait[2m])) * 100) > 20
      for: 2m
      labels:
        severity: critical
      annotations:
        summary: "High CPU I/O wait (instance {{ $labels.instance }})"
        description: "CPU I/O wait is greater than 20%\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P2

    - alert: DiskUsedPercentHigh
      expr: disk_used_percent > 90
      for: 2m
      labels:
        severity: critical
      annotations:
        summary: "High disk usage percent (instance {{ $labels.instance }})"
        description: "Disk usage percent is greater than 90%\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P1

    - alert: DiskLatencyHigh
      expr: diskio_read_time / rate(diskio_reads[1m]) > 0.1 and rate(diskio_reads[1m]) > 0 or diskio_write_time / rate(diskio_writes[1m]) > 0.1 and rate(diskio_writes[1m]) > 0
      for: 2m
      labels:
        severity: warning
      annotations:
        summary: "High disk latency (instance {{ $labels.instance }})"
        description: "Disk read or write operations latency is greater than 100ms\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P3

    - alert: InternalAgentIssues
      expr: internal_agent_gather_errors > 0 or internal_agent_gather_timeouts > 5 or internal_agent_metrics_dropped > 0 or internal_agent_metrics_gathered < 90 or internal_agent_metrics_written < 90
      for: 2m
      labels:
        severity: critical
      annotations:
        summary: "Internal agent issues (instance {{ $labels.instance }})"
        description: "Internal agent has gather errors, timeouts, dropped metrics, or low metrics gathered/written\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P1

    - alert: MemoryUsageHigh
      expr: mem_available_percent < 10
      for: 2m
      labels:
        severity: critical
      annotations:
        summary: "High memory usage (instance {{ $labels.instance }})"
        description: "Memory active usage is greater than 90%, or available memory is less than 10%\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"          
        priority: P1

    - alert: SwapUsageHigh
      expr: swap_used_percent > 80
      for: 2m
      labels:
        severity: critical
      annotations:
        summary: "High swap usage (instance {{ $labels.instance }})"
        description: "Swap free space is less than 20% or swap used percent is greater than 80%\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P1

    - alert: ProcessesDead
      expr: processes_dead > 0
      for: 2m
      labels:
        severity: critical
      annotations:
        summary: "Processes dead (instance {{ $labels.instance }})"
        description: "There are dead processes\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P1

    - alert: ProcessesZombies
      expr: processes_zombies > 5
      for: 2m
      labels:
        severity: warning
      annotations:
        summary: "Processes zombies high (instance {{ $labels.instance }})"
        description: "There are more than 5 zombie processes\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P2

    - alert: SoftnetStatIssues
      expr: softnet_stat_cpu_collision > 0 or softnet_stat_packet_drops > 0
      for: 2m
      labels:
        severity: critical
      annotations:
        summary: "Softnet stat issues (instance {{ $labels.instance }})"
        description: "Softnet CPU collisions or packet drops detected\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P1

    - alert: ServiceDown
      expr: up{job="ceph"} == 0
      for: 5m
      labels:
        severity: critical
      annotations:
        summary: "Service down (instance {{ $labels.instance }})"
        description: "Service is down\n  VALUE = {{ $value }}\n  LABELS: {{ $labels }}"
        priority: P1
