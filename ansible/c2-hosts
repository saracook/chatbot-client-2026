  vars:
    ansible_python_interpreter: /usr/bin/python3
    ansible_ssh_private_key_file: /dev/shm/ansible.pem
    ansible_ssh_public_key_file: /dev/shm/ansible.pub
    domain: stanford.edu
    timezone: America/Los_Angeles
    locale: en_US.UTF-8
    ntp_server: time.stanford.edu
    network_vlan: 3038
    network_addr: 10.112.12.0
    network_prefix: 22
    network_cidr: "{{ network_addr }}/{{ network_prefix }}"
    network_mask: "{{ network_cidr | ansible.utils.ipaddr('netmask') }}"
    network_gateway: "{{ network_cidr | ansible.utils.next_nth_usable(1) }}"
    network_dns: [171.64.1.234, 171.67.1.234]
    network_mtu: 9000
    distro: rocky
    distro_version: 10.0
    distro_container_name: docker.io/rockylinux/rockylinux
    distro_container_tag: "{{ distro_version }}"
    distro_container_image: "{{ distro_container_name }}:{{ distro_container_tag }}"
    ansible_user: rocky
    default_user: rocky
    default_user_gecos: Rocky Linux
    default_user_groups: [adm, systemd-journal]
    default_password: "{{ lookup('env', 'DEFAULT_PASSWORD') }}"
    slurm_version: 25.05.3
    nginx_ip: "{{ hostvars[groups['c2_pxe_server'][0]]['ansible_host'] }}"
    nginx_port: 8000
    rpm_repo_ip: "{{ hostvars[groups['c2_rpm_repo_server'][0]]['ansible_host'] }}"
    rpm_repo_port: 8000
