    ansible_ssh_private_key_file: "{{ lookup('env', 'ANSIBLE_SSH_PRIVATE_KEY_FILE') }}"
    ansible_ssh_public_key_file: "{{ lookup('env', 'ANSIBLE_SSH_PUBLIC_KEY_FILE') }}"
    ansible_managed: "This file is managed by Ansible. Changes to it may be overwritten."
    domain: stanford.edu
    timezone: America/Los_Angeles
    locale: en_US.UTF-8
    ntp_server: time.stanford.edu
    network_access_vlan: 3038
    network_trunk_vlans: [2008,2009]
    network_mtu: 9000
    network_vpn_cidrs:
      - 10.130.0.0/16
      - 10.131.0.0/16
    network_access_addr: 10.112.12.0
    network_access_prefix: 22
    network_access_cidr: "{{ network_access_addr }}/{{ network_access_prefix }}"
    network_access_mask: "{{ network_access_cidr | ansible.utils.ipaddr('netmask') }}"
    network_access_gateway: 10.112.12.1
    network_access_dns:
      # todo: srv records for slurm configless via dnsmasq
      - 10.112.12.2
      - 171.64.1.234
      - 171.67.1.234
    network_access_dns_search:
      - "{{ domain }}"
    network_mgmt_addr: 10.210.24.0
    network_mgmt_prefix: 22
    network_mgmt_cidr: "{{ network_mgmt_addr }}/{{ network_mgmt_prefix }}"
    network_mgmt_mask: "{{ network_mgmt_cidr | ansible.utils.ipaddr('netmask') }}"
    network_mgmt_gateway: 10.210.24.2
    network_mgmt_dns:
      - 10.210.24.2
    network_mgmt_dns_search:
      - "{{ domain }}"
    network_cluster_addr: 10.210.28.0
    network_cluster_prefix: 22
    network_cluster_cidr: "{{ network_cluster_addr }}/{{ network_cluster_prefix }}"
    network_cluster_mask: "{{ network_cluster_cidr | ansible.utils.ipaddr('netmask') }}"
    network_cluster_gateway: 10.210.28.2
    network_cluster_dns:
      - 10.210.28.2
    network_cluster_dns_search:
      - "{{ domain }}"
    # default distro. must be one of the keys in distros.
    # override in host/group vars to select a different version.
    distro: rocky_10_0
    distros:
      rocky_9_6:
        el: el9
        version: '9.6'
        version_major: '9'
        name: rocky-9.6
        iso_url: http://dl.rockylinux.org/pub/rocky/9.6/isos/x86_64/Rocky-9.6-x86_64-minimal.iso
        iso_sha256: aed9449cf79eb2d1c365f4f2561f923a80451b3e8fdbf595889b4cf0ac6c58b8
        iso_pxe_linux: rocky-9.6/images/pxeboot/vmlinuz
        iso_pxe_initrd: rocky-9.6/images/pxeboot/initrd.img
      rocky_10_0:
        el: el10
        version: '10.0'
        version_major: '10'
        name: rocky-10.0
        iso_url: http://dl.rockylinux.org/pub/rocky/10.0/isos/x86_64/Rocky-10.0-x86_64-minimal.iso
        iso_sha256: de75c2f7cc566ea964017a1e94883913f066c4ebeb1d356964e398ed76cadd12
        iso_pxe_linux: rocky-10.0/images/pxeboot/vmlinuz
        iso_pxe_initrd: rocky-10.0/images/pxeboot/initrd.img
    ansible_user: rocky
    default_user: rocky
    default_user_uid: 1000
    default_user_gecos: Rocky Linux
    default_user_groups: [adm, systemd-journal]
    default_password: "{{ lookup('env', 'DEFAULT_PASSWORD') }}"
    slurm_version: 25.05.3
    slurm_cluster_name: c2
    nginx_ip: "{{ hostvars[groups['c2_pxe_server'][0]]['ansible_host'] }}"
    nginx_port: 8000
    rpm_repo_ip: "{{ hostvars[groups['c2_rpm_repo_server'][0]]['ansible_host'] }}"
    rpm_repo_port: 8000
