apiVersion: v1
kind: Service
metadata:
  name: proxy-api
  namespace: jupyter
  annotations:
    configmanagement.gke.io/cluster-selector: jupyterhub-proxy
spec:
  clusterIP: 10.152.236.150
  externalTrafficPolicy: Cluster
  ports:
  - nodePort: 32388
    port: 8001
    protocol: TCP
    targetPort: 8001
  selector:
    component: proxy
  sessionAffinity: None
  type: LoadBalancer
