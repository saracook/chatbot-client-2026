apiVersion: v1
kind: Service
metadata:
  name: proxy-http
  namespace: jupyter
  annotations:
    configmanagement.gke.io/cluster-selector: jupyterhub-proxy
spec:
  clusterIP: 10.152.180.174
  externalTrafficPolicy: Cluster
  ports:
  - nodePort: 31064
    port: 8000
    protocol: TCP
    targetPort: 8000
  selector:
    component: proxy
  sessionAffinity: None
  type: NodePort
