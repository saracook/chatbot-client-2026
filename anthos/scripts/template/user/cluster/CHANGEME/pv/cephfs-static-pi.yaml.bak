apiVersion: v1
kind: PersistentVolume
metadata:
  annotations:
  name: cephfs-static-pi-neals
spec:
  accessModes:
  - ReadWriteMany
  capacity:
    storage: 498T
  claimRef:
  csi:
    driver: cephfs.csi.ceph.com
    nodeStageSecretRef:
      name: csi-cephfs-pi-client-secret
      namespace: cephfs
    volumeAttributes:
      clusterID: cc06bc72-cacd-11eb-8bdd-97416ba6ca5f
      fsName: hc-fs
      rootPath: /volumes/stanford/pi/8a38c8df-cfcd-4d8c-bee5-ad121dcc50b3
      staticVolume: "true"
    volumeHandle: cephfs-static-pi-neals
  persistentVolumeReclaimPolicy: Retain
  volumeMode: Filesystem
