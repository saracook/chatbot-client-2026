apiVersion: v1
kind: PersistentVolume
metadata:
  annotations:
  name: static-share-sw-neals
spec:
  accessModes:
  - ReadOnlyMany
  capacity:
    storage: 500G
  claimRef:
  mountOptions:
  - noload
  - ro
  rbd:
    fsType: ext4
    image: sw-share-ro-2021-09-28
    #keyring: /etc/ceph/keyring
    monitors:
    - 192.168.2.17 
    - 192.168.2.26
    - 192.168.2.6
    pool: nvme-rbd
    readOnly: true
    secretRef:
      name:  rbd-keyring
      namespace: ceph-rbd
    user: kubernetes-rbd-provisioner
  volumeMode: Filesystem
  persistentVolumeReclaimPolicy: Retain
